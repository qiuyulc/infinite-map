{
  "name": "@qiuyulc/infinite-map",
  "version": "0.1.0",
  "description": "Infinite canvas editor (React) with plugins: minimap, rulers, snapping, etc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiuyulc/infinite-map.git"
  },
  "homepage": "https://github.com/qiuyulc/infinite-map",
  "bugs": {
    "url": "https://github.com/qiuyulc/infinite-map/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "types": "./es/index.d.mts",
  "exports": {
    ".": {
      "types": "./es/index.d.mts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./ui": {
      "types": "./es/ui/index.d.mts",
      "import": "./es/ui/index.js",
      "require": "./lib/ui/index.js"
    },
    "./demo": {
      "types": "./es/demo/index.d.mts",
      "import": "./es/demo/index.js",
      "require": "./lib/demo/index.js"
    },
    "./es/*": {
      "types": "./es/*.d.mts",
      "import": "./es/*.js"
    },
    "./lib/*": {
      "types": "./lib/*.d.mts",
      "require": "./lib/*.js"
    }
  },
  "files": [
    "es",
    "lib"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0"
  }
}
