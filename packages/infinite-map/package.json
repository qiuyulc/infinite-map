{
  "name": "@qiuyulc/infinite-map",
  "version": "0.0.6",
  "description": "Infinite canvas renderer for React — world coordinates, spatial index, plugin protocol, document serialization.",
  "license": "MIT",
  "keywords": [
    "infinite-canvas",
    "whiteboard",
    "canvas",
    "react",
    "renderer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiuyulc/infinite-map.git"
  },
  "homepage": "https://github.com/qiuyulc/infinite-map",
  "bugs": {
    "url": "https://github.com/qiuyulc/infinite-map/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "types": "./es/index.d.mts",
  "exports": {
    ".": {
      "types": "./es/index.d.mts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./ui": {
      "types": "./es/ui/index.d.mts",
      "import": "./es/ui/index.js",
      "require": "./lib/ui/index.js"
    },
    "./demo": {
      "types": "./es/demo/index.d.mts",
      "import": "./es/demo/index.js",
      "require": "./lib/demo/index.js"
    },
    "./es/*": {
      "types": "./es/*.d.mts",
      "import": "./es/*.js"
    },
    "./lib/*": {
      "types": "./lib/*.d.mts",
      "require": "./lib/*.js"
    }
  },
  "files": [
    "es",
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zustand": "^5.0.12"
  }
}
