{
  "name": "@qiuyulc/infinite-map-editor",
  "version": "0.1.0",
  "description": "Editor plugins & UI kit for @qiuyulc/infinite-map",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiuyulc/infinite-map.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./lib/index.js",
  "module": "./es/index.js",
  "types": "./es/index.d.mts",
  "exports": {
    ".": {
      "types": "./es/index.d.mts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./es/*": {
      "types": "./es/*.d.mts",
      "import": "./es/*.js"
    },
    "./lib/*": {
      "types": "./lib/*.d.mts",
      "require": "./lib/*.js"
    }
  },
  "files": [
    "es",
    "lib"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qiuyulc/infinite-map": "workspace:*"
  },
  "peerDependencies": {
    "@qiuyulc/infinite-map": "^0.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^2.1.8"
  }
}
