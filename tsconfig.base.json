{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@qiuyulc/infinite-map": ["packages/infinite-map/src/index.ts"],
      "@qiuyulc/infinite-map/*": ["packages/infinite-map/src/*"],
      "@qiuyulc/infinite-map-editor": ["packages/infinite-map-editor/src/index.ts"],
      "@qiuyulc/infinite-map-editor/*": ["packages/infinite-map-editor/src/*"]
    },
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true
  }
}
