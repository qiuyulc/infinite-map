{
  "name": "infinite-map",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "dev:docs": "pnpm -C site dev",
    "build:docs": "pnpm -C site build",
    "preview:docs": "pnpm -C site preview",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify:exports": "node scripts/verify-exports.mjs",
    "check": "pnpm typecheck && pnpm build && pnpm test && pnpm verify:exports",
    "changeset": "pnpm exec changeset",
    "changeset:status": "pnpm exec changeset status --verbose",
    "version-packages": "pnpm exec changeset version && pnpm install --lockfile-only",
    "release": "pnpm check && pnpm exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@rolldown/binding-linux-arm64-gnu": "1.0.0-rc.16",
    "@rollup/rollup-linux-arm64-gnu": "4.60.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.4",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitepress": "1.6.4",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.16",
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  }
}
